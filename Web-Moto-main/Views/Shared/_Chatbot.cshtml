<!-- MotoBike AI Chatbot Widget v2 -->
<style>
@@import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@700;800&display=swap');

:root {
    --chat-primary: #E8320A;
    --chat-secondary: #FF6B35;
    --chat-dark: #1A1A2E;
    --chat-surface: #16213E;
    --chat-accent: #F5A623;
    --chat-safe: #00C851;
    --chat-warn: #FF8800;
    --chat-danger: #E8320A;
}

/* ── FAB ─────────────────────────────────────────────────────── */
#chat-fab {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: var(--chat-primary);
    color: #fff;
    border: none;
    cursor: pointer;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    box-shadow: 0 4px 20px rgba(232,50,10,0.45), 0 0 0 0 rgba(232,50,10,0.3);
    transition: transform .2s, box-shadow .2s;
    animation: fabPulse 2.5s infinite;
}
@@keyframes fabPulse {
    0%,100% { box-shadow: 0 4px 20px rgba(232,50,10,0.45), 0 0 0 0 rgba(232,50,10,0.3); }
    50%      { box-shadow: 0 4px 20px rgba(232,50,10,0.45), 0 0 0 12px rgba(232,50,10,0); }
}
#chat-fab:hover { transform: scale(1.1); animation: none; box-shadow: 0 8px 30px rgba(232,50,10,0.6); }

#chat-fab .fab-badge {
    position: absolute;
    top: -3px; right: -3px;
    background: var(--chat-accent);
    color: #1A1A2E;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    font-weight: 800;
    padding: 2px 5px;
    border-radius: 8px;
    border: 2px solid #fff;
    letter-spacing: .5px;
}

/* ── Chat Box ─────────────────────────────────────────────────── */
#chat-box {
    position: fixed;
    bottom: 104px;
    right: 28px;
    width: 370px;
    height: 560px;
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 16px 60px rgba(0,0,0,0.2);
    z-index: 9999;
    display: none;
    flex-direction: column;
    overflow: hidden;
    font-family: 'Barlow', sans-serif;
    animation: chatSlideUp .28s cubic-bezier(.34,1.56,.64,1);
}
@@keyframes chatSlideUp {
    from { opacity: 0; transform: translateY(24px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
}
#chat-box.open { display: flex; }

/* ── Header ──────────────────────────────────────────────────── */
#chat-header {
    background: var(--chat-dark);
    padding: 0 18px;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
}
#chat-header::before {
    content: '';
    position: absolute;
    top: -20px; right: -20px;
    width: 100px; height: 100px;
    background: var(--chat-primary);
    border-radius: 50%;
    opacity: .15;
}
#chat-header::after {
    content: '';
    position: absolute;
    bottom: -30px; right: 40px;
    width: 70px; height: 70px;
    background: var(--chat-accent);
    border-radius: 50%;
    opacity: .1;
}

.chat-avatar-wrap {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--chat-primary), var(--chat-secondary));
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    position: relative; z-index: 1;
}
.chat-header-info { flex: 1; position: relative; z-index: 1; }
.chat-header-name {
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 800;
    letter-spacing: .5px;
    margin: 0;
    text-transform: uppercase;
}
.chat-header-status {
    color: rgba(255,255,255,0.6);
    font-size: 12px;
    margin: 0;
    display: flex; align-items: center; gap: 5px;
}
.status-dot {
    width: 7px; height: 7px;
    background: var(--chat-safe);
    border-radius: 50%;
    animation: blink 1.8s infinite;
}
@@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }

#chat-close {
    background: rgba(255,255,255,0.1);
    border: none;
    color: rgba(255,255,255,0.7);
    width: 32px; height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    transition: all .2s;
    position: relative; z-index: 1;
}
#chat-close:hover { background: rgba(255,255,255,0.2); color: #fff; }

/* ── Safety Alert Banner ─────────────────────────────────────── */
#safety-banner {
    display: none;
    background: linear-gradient(135deg, #1A1A2E, #2d1b00);
    border-bottom: 3px solid var(--chat-danger);
    padding: 10px 16px;
    flex-shrink: 0;
    animation: bannerSlide .3s ease;
}
@@keyframes bannerSlide { from{opacity:0;transform:translateY(-8px)} to{opacity:1;transform:translateY(0)} }
#safety-banner.show { display: flex; align-items: flex-start; gap: 10px; }

.safety-icon {
    font-size: 22px;
    flex-shrink: 0;
    animation: shake .5s ease;
}
@@keyframes shake {
    0%,100%{transform:rotate(0)} 25%{transform:rotate(-8deg)} 75%{transform:rotate(8deg)}
}
.safety-content { flex: 1; }
.safety-title {
    color: var(--chat-accent);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin: 0 0 3px;
}
.safety-text {
    color: rgba(255,255,255,0.75);
    font-size: 11.5px;
    line-height: 1.5;
    margin: 0;
}
.safety-gear {
    display: flex; flex-wrap: wrap; gap: 4px;
    margin-top: 6px;
}
.safety-tag {
    background: rgba(232,50,10,0.15);
    border: 1px solid rgba(232,50,10,0.4);
    color: #ff9d87;
    font-size: 10.5px;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 600;
}
#safety-close {
    background: none; border: none;
    color: rgba(255,255,255,0.4); font-size: 16px;
    cursor: pointer; padding: 0; flex-shrink: 0;
    transition: color .2s;
}
#safety-close:hover { color: #fff; }

/* ── Messages ─────────────────────────────────────────────────── */
#chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: #f4f5f9;
}
#chat-messages::-webkit-scrollbar { width: 3px; }
#chat-messages::-webkit-scrollbar-thumb { background: #ddd; border-radius: 2px; }

.msg {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    max-width: 92%;
}
.msg.bot  { align-self: flex-start; }
.msg.user { align-self: flex-end; flex-direction: row-reverse; }

.msg-avatar {
    width: 32px; height: 32px;
    border-radius: 10px;
    background: var(--chat-dark);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
}
.msg-bubble {
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 13.5px;
    line-height: 1.55;
    max-width: 265px;
    word-break: break-word;
}
.msg.bot .msg-bubble {
    background: #fff;
    color: #2c2c3e;
    border-bottom-left-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
}
.msg.user .msg-bubble {
    background: linear-gradient(135deg, var(--chat-primary), var(--chat-secondary));
    color: #fff;
    border-bottom-right-radius: 4px;
}

/* Safety message bubble variant */
.msg.bot .msg-bubble.safety-msg {
    background: linear-gradient(135deg, #1A1A2E, #2a1500);
    color: #fff;
    border-left: 3px solid var(--chat-accent);
}

/* Typing */
.typing-dots { display: flex; gap: 5px; padding: 10px 4px; }
.typing-dots span {
    width: 8px; height: 8px;
    background: #bbb;
    border-radius: 50%;
    animation: typeBounce .9s infinite;
}
.typing-dots span:nth-child(2) { animation-delay: .15s; }
.typing-dots span:nth-child(3) { animation-delay: .3s; }
@@keyframes typeBounce {
    0%,60%,100% { transform: translateY(0); }
    30%          { transform: translateY(-7px); }
}

/* Timestamp */
.msg-time {
    font-size: 10px;
    color: #aaa;
    margin-top: 3px;
    padding: 0 4px;
    align-self: flex-end;
    margin-bottom: 2px;
}
.msg.user .msg-time { text-align: right; }

/* ── Quick Chips ──────────────────────────────────────────────── */
#chat-suggestions {
    padding: 8px 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    background: #f4f5f9;
    border-top: 1px solid #eaeaf0;
    flex-shrink: 0;
}
.suggestion-chip {
    background: #fff;
    border: 1.5px solid #e0e0ea;
    color: #444;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-family: 'Barlow', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
}
.suggestion-chip:hover,
.suggestion-chip.sport {
    background: var(--chat-dark);
    color: #fff;
    border-color: var(--chat-dark);
}
.suggestion-chip.speed:hover {
    background: var(--chat-primary);
    border-color: var(--chat-primary);
    color: #fff;
}

/* ── Input ────────────────────────────────────────────────────── */
#chat-input-area {
    padding: 10px 14px;
    display: flex;
    gap: 8px;
    align-items: center;
    border-top: 1px solid #eaeaf0;
    background: #fff;
    flex-shrink: 0;
}
#chat-input {
    flex: 1;
    border: 1.5px solid #e4e4ef;
    border-radius: 22px;
    padding: 9px 16px;
    font-size: 13.5px;
    font-family: 'Barlow', sans-serif;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    background: #f8f8fc;
    color: #2c2c3e;
    resize: none;
}
#chat-input:focus {
    border-color: var(--chat-primary);
    box-shadow: 0 0 0 3px rgba(232,50,10,0.1);
    background: #fff;
}
#chat-input::placeholder { color: #aaa; }

#chat-send {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--chat-dark);
    border: none;
    color: #fff;
    font-size: 15px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all .2s;
}
#chat-send:hover { background: var(--chat-primary); transform: scale(1.08); }
#chat-send:disabled { opacity: .4; cursor: not-allowed; transform: none; }

/* ── Responsive ───────────────────────────────────────────────── */
@@media (max-width: 420px) {
    #chat-box { width: calc(100vw - 28px); right: 14px; height: 80vh; }
    #chat-fab { right: 16px; bottom: 16px; }
}
</style>

<!-- FAB -->
<button id="chat-fab" onclick="toggleChat()" title="Tư vấn AI">
    <i class="fas fa-motorcycle"></i>
    <span class="fab-badge">AI</span>
</button>

<!-- Chat Box -->
<div id="chat-box">
    <!-- Header -->
    <div id="chat-header">
        <div class="chat-avatar-wrap">🏍️</div>
        <div class="chat-header-info">
            <p class="chat-header-name">MotoBike Advisor</p>
            <p class="chat-header-status">
                <span class="status-dot"></span>
                Sẵn sàng tư vấn
            </p>
        </div>
        <button id="chat-close" onclick="toggleChat()">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <!-- Safety Banner (hidden by default, shown when sport/speed intent detected) -->
    <div id="safety-banner">
        <div class="safety-icon">⚠️</div>
        <div class="safety-content">
            <p class="safety-title">🏁 Lưu ý An Toàn Khi Lái Xe Thể Thao</p>
            <p class="safety-text">Xe phân khối lớn / tốc độ cao đòi hỏi trang bị bảo hộ đầy đủ và kỹ năng lái đúng chuẩn.</p>
            <div class="safety-gear">
                <span class="safety-tag">🪖 Mũ full-face</span>
                <span class="safety-tag">🧤 Găng tay bảo hộ</span>
                <span class="safety-tag">🦺 Áo giáp</span>
                <span class="safety-tag">👢 Giày riding</span>
            </div>
        </div>
        <button id="safety-close" onclick="hideSafetyBanner()">✕</button>
    </div>

    <!-- Messages -->
    <div id="chat-messages">
        <div class="msg bot">
            <div class="msg-avatar">🤖</div>
            <div class="msg-bubble">
                Xin chào! Tôi là <strong>MotoBike Advisor</strong> — AI tư vấn xe của bạn. 🏍️<br><br>
                Hãy cho tôi biết bạn cần gì: đi làm hàng ngày, phượt đường dài, hay xe thể thao tốc độ cao?
            </div>
        </div>
    </div>

    <!-- Quick Suggestions -->
    <div id="chat-suggestions">
        <button class="suggestion-chip" onclick="sendSuggestion(this)">🏙️ Xe đi làm</button>
        <button class="suggestion-chip" onclick="sendSuggestion(this)">🏕️ Xe phượt</button>
        <button class="suggestion-chip speed" onclick="sendSuggestion(this)">⚡ Xe thể thao</button>
        <button class="suggestion-chip" onclick="sendSuggestion(this)">💰 Dưới 40 triệu</button>
        <button class="suggestion-chip" onclick="sendSuggestion(this)">⛽ Tiết kiệm xăng</button>
    </div>

    <!-- Input -->
    <div id="chat-input-area">
        <input id="chat-input" type="text"
               placeholder="Nhập câu hỏi của bạn..."
               onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();sendMessage();}" />
        <button id="chat-send" onclick="sendMessage()" title="Gửi">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

<script>
(function () {
    const chatBox      = document.getElementById('chat-box');
    const chatMessages = document.getElementById('chat-messages');
    const chatInput    = document.getElementById('chat-input');
    const chatSend     = document.getElementById('chat-send');
    const suggestions  = document.getElementById('chat-suggestions');
    const safetyBanner = document.getElementById('safety-banner');

    let history = [];
    let safetyShown = false;

    // ── Từ khoá kích hoạt cảnh báo an toàn ──────────────────────
    const SPORT_KEYWORDS = [
        'tốc độ', 'nhanh', 'mạnh', 'phân khối lớn', 'pkl', 'sport', 'thể thao',
        'mạo hiểm', 'đua', 'racing', 'drift', 'stunt', 'pkl', '650', '750', '1000',
        'r15', 'r3', 'cbr', 'zx', 'ninja', 'streetfighter', 'superbike',
        'adrenaline', 'cảm giác mạnh', 'hú ga', 'siêu xe', 'pkl', '300cc', '400cc'
    ];

    function detectSportIntent(text) {
        const lower = text.toLowerCase();
        return SPORT_KEYWORDS.some(kw => lower.includes(kw));
    }

    // ── Helpers ──────────────────────────────────────────────────
    window.toggleChat = function () {
        chatBox.classList.toggle('open');
        if (chatBox.classList.contains('open')) {
            chatInput.focus();
            scrollBottom();
        }
    };

    function scrollBottom() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function now() {
        return new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
    }

    function appendMessage(role, html, isSafety = false) {
        const isBot = role === 'assistant';
        const wrap  = document.createElement('div');
        wrap.className = `msg ${isBot ? 'bot' : 'user'}`;

        const avatar     = document.createElement('div');
        avatar.className = 'msg-avatar';
        avatar.textContent = isBot ? '🤖' : '👤';

        const bubble     = document.createElement('div');
        bubble.className = 'msg-bubble' + (isSafety ? ' safety-msg' : '');
        bubble.innerHTML = html;

        const time     = document.createElement('div');
        time.className = 'msg-time';
        time.textContent = now();

        const inner = document.createElement('div');
        inner.style.display = 'flex';
        inner.style.flexDirection = 'column';

        inner.appendChild(bubble);
        inner.appendChild(time);

        if (isBot) { wrap.appendChild(avatar); wrap.appendChild(inner); }
        else       { wrap.appendChild(inner);  wrap.appendChild(avatar); }

        chatMessages.appendChild(wrap);
        scrollBottom();
    }

    function textToHtml(text) {
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\n/g, '<br>')
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    }

    function showTyping() {
        const div = document.createElement('div');
        div.className = 'msg bot';
        div.id = 'chat-typing';
        div.innerHTML = `<div class="msg-avatar">🤖</div>
            <div class="msg-bubble">
              <div class="typing-dots"><span></span><span></span><span></span></div>
            </div>`;
        chatMessages.appendChild(div);
        scrollBottom();
    }

    function hideTyping() {
        const el = document.getElementById('chat-typing');
        if (el) el.remove();
    }

    function showSafetyBanner() {
        if (!safetyShown) {
            safetyBanner.classList.add('show');
            safetyShown = true;
        }
    }

    window.hideSafetyBanner = function () {
        safetyBanner.classList.remove('show');
    };

    window.sendSuggestion = function (btn) {
        chatInput.value = btn.textContent.replace(/^[^\w\u00C0-\u024F\u1E00-\u1EFF]+/, '').trim();
        suggestions.style.display = 'none';
        sendMessage();
    };

    // ── Main send ────────────────────────────────────────────────
    async function sendMessage() {
        const text = chatInput.value.trim();
        if (!text || chatSend.disabled) return;

        chatInput.value   = '';
        chatSend.disabled = true;
        suggestions.style.display = 'none';

        // Kiểm tra intent thể thao/tốc độ
        if (detectSportIntent(text)) {
            showSafetyBanner();
        }

        appendMessage('user', textToHtml(text));
        history.push({ role: 'user', content: text });

        showTyping();

        try {
            const res = await fetch('/Chat/Send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message: text,
                    history: history.slice(0, -1)
                })
            });

            const data = await res.json();
            hideTyping();

            const reply = data.reply || 'Xin lỗi, có lỗi xảy ra.';

            // Nếu reply chứa nội dung về an toàn → render bubble tối
            const isSafetyReply = reply.toLowerCase().includes('an toàn') ||
                                  reply.toLowerCase().includes('bảo hộ') ||
                                  reply.toLowerCase().includes('mũ bảo hiểm');

            appendMessage('assistant', textToHtml(reply), isSafetyReply);

            history.push({ role: 'assistant', content: reply });
            if (history.length > 20) history = history.slice(-20);

        } catch (err) {
            hideTyping();
            appendMessage('assistant', 'Xin lỗi, tôi đang gặp sự cố. Vui lòng thử lại. 🙏');
            console.error('[CHAT]', err);
        }

        chatSend.disabled = false;
        chatInput.focus();
    }

    window.sendMessage = sendMessage;
})();
</script>
