@model MotoBikeStore.Models.Product
@{ 
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Xóa sản phẩm";
}

<style>
.delete-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
}

.delete-card {
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    padding: 2.5rem 2rem;
    max-width: 500px;
    width: 100%;
    text-align: center;
    border: 1px solid #ffe0e0;
    animation: slideUp 0.35s cubic-bezier(0.34,1.56,0.64,1);
}
@@keyframes slideUp {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* Icon */
.delete-icon-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
}
.delete-icon {
    width: 80px; height: 80px;
    background: linear-gradient(135deg, #fff0f0, #ffe0e0);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; color: #e53935;
    border: 3px solid #ffc5c5;
    animation: pulse 2s ease infinite;
}
@@keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(229,57,53,0.25); }
    50%       { box-shadow: 0 0 0 14px rgba(229,57,53,0); }
}

/* Product preview */
.delete-product-preview {
    display: flex; align-items: center; gap: 1rem;
    background: #fafafa;
    border-radius: 16px;
    padding: 1rem 1.25rem;
    margin: 1.25rem 0 1.75rem;
    border: 1px solid #f0f0f0;
    text-align: left;
}
.delete-product-preview img {
    width: 72px; height: 72px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid #eee;
    flex-shrink: 0;
}
.delete-product-info { flex: 1; min-width: 0; }
.delete-product-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #1a1a2e;
    margin: 0 0 4px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.delete-product-brand {
    font-size: 0.8rem;
    color: #888;
    margin: 0;
}
.delete-product-price {
    font-weight: 800;
    font-size: 1rem;
    color: #e53935;
    margin: 0;
    white-space: nowrap;
}

/* Title & desc */
.delete-title {
    font-size: 1.4rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 0.4rem;
}
.delete-desc {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 1.75rem;
    line-height: 1.5;
}
.delete-warning {
    background: #fff8e1;
    border: 1px solid #ffe082;
    border-radius: 10px;
    padding: 0.6rem 1rem;
    font-size: 0.82rem;
    color: #f57f17;
    margin-bottom: 1.75rem;
    display: flex; align-items: center; gap: 0.5rem;
}

/* Buttons */
.delete-actions {
    display: flex; gap: 0.85rem;
}
.btn-cancel {
    flex: 1; padding: 0.85rem;
    border-radius: 12px;
    border: 2px solid #e0e0e0;
    background: transparent;
    color: #555;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    display: flex; align-items: center; justify-content: center;
    gap: 0.4rem;
    transition: all 0.2s;
}
.btn-cancel:hover {
    background: #f5f5f5;
    border-color: #bbb;
    color: #333;
}
.btn-delete-confirm {
    flex: 1; padding: 0.85rem;
    border-radius: 12px;
    background: linear-gradient(135deg, #e53935, #c62828);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    gap: 0.4rem;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(229,57,53,0.35);
}
.btn-delete-confirm:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(229,57,53,0.45);
}
</style>

<div class="delete-page">
    <div class="delete-card">
        <!-- Icon -->
        <div class="delete-icon-wrap">
            <div class="delete-icon">
                <i class="fas fa-trash-alt"></i>
            </div>
        </div>

        <!-- Tiêu đề -->
        <h4 class="delete-title">Xóa sản phẩm?</h4>
        <p class="delete-desc">Hành động này không thể hoàn tác. Sản phẩm sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>

        <!-- Preview sản phẩm -->
        <div class="delete-product-preview">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" />
            }
            else
            {
                <div style="width:72px;height:72px;border-radius:12px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#ccc;font-size:1.5rem;">
                    <i class="fas fa-image"></i>
                </div>
            }
            <div class="delete-product-info">
                <p class="delete-product-name">@Model.Name</p>
                <p class="delete-product-brand">@Model.Brand</p>
            </div>
            <p class="delete-product-price">@Model.Price.ToString("N0")₫</p>
        </div>

        <!-- Cảnh báo -->
        <div class="delete-warning">
            <i class="fas fa-exclamation-triangle"></i>
            Sản phẩm sẽ bị xóa khỏi tất cả danh sách và không thể phục hồi.
        </div>

        <!-- Buttons -->
        <div class="delete-actions">
            <a class="btn-cancel" href="/Products">
                <i class="fas fa-arrow-left"></i>Hủy bỏ
            </a>
            <form method="post" style="flex:1; display:contents;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-delete-confirm">
                    <i class="fas fa-trash-alt"></i>Xóa vĩnh viễn
                </button>
            </form>
        </div>
    </div>
</div>
